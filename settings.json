{
    // Appearance
    "theme": "Aura Dark",
    "icon_theme": "Soft Charmed Icons",
    "theme_overrides": {
        "Aura Dark": {
            "border.variant": "#15141C",
            "border": "#15141C",
            "title_bar.background": "#15141C",
            "panel.background": "#15141C",
            "panel.focused_border": "#4E466E",
            "players": [
                {
                    "cursor": "#bd9dff"
                }
            ],
            "syntax": {
                "comment": {
                    "font_style": "italic"
                },
                "comment.doc": {
                    "font_style": "italic"
                }
            }
        }
    },

    // Fonts
    "ui_font_family": "FiraCode Nerd Font Mono",
    "ui_font_size": 14,
    "buffer_font_family": "FiraCode Nerd Font Mono",
    "buffer_font_size": 14,
    "buffer_line_height": {
        "custom": 2
    },

    // Editor behavior
    "base_keymap": "VSCode",
    "tab_size": 4,
    "hard_tabs": false,
    "auto_indent": "preserve_indent",
    "formatter": "prettier",
    "use_on_type_format": false,
    "semantic_tokens": "combined",

    // Minimap
    "minimap": {
        "show": "always",
        "thumb_border": "right_open"
    },

    // Gutter
    "gutter": {
        "min_line_number_digits": 0,
        "folds": false,
        "runnables": false,
        "breakpoints": false,
        "bookmarks": false
    },

    // Tabs & title bar
    "tabs": {
        "git_status": true
    },
    "title_bar": {
        "show_branch_status_icon": true
    },

    // Panels
    "outline_panel": {
        "dock": "left"
    },
    "collaboration_panel": {
        "dock": "left"
    },
    "git_panel": {
        "dock": "left"
    },
    "project_panel": {
        "default_width": 400,
        "dock": "right",
        "hide_root": true,
        "auto_fold_dirs": false,
        "git_status_indicator": true
    },

    // Agent
    "agent": {
        "button": true,
        "dock": "left"
    },
    "agent_ui_font_size": 14,
    "agent_buffer_font_size": 14,
    "agent_servers": {
        "claude-acp": {
            "type": "registry"
        }
    },

    // Language-specific settings
    "languages": {
        "Vue.js": {
            "tasks": {
                "enabled": true,
                "prefer_lsp": true
            },
            "show_wrap_guides": false,
            "use_on_type_format": true,
            "colorize_brackets": false,
            "inlay_hints": {
                "enabled": false
            },
            "indent_guides": {
                "enabled": true,
                "background_coloring": "disabled",
                "coloring": "fixed"
            },
            "soft_wrap": "editor_width",
            "auto_indent": "preserve_indent"
        }
    },

    // File finder
    "file_finder": {
        "modal_max_width": "large"
    },

    // Session & trust
    "session": {
        "trust_all_worktrees": true
    },

    // Privacy
    "telemetry": {
        "diagnostics": false,
        "metrics": false
    }
}
